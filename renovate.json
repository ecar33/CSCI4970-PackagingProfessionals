{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Chicago",
  "schedule": ["before 6am on Monday"],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "separateMajorMinor": true,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Group all non-major Python dependency updates into one PR",
      "matchManagers": ["pip_requirements"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Python dependencies (non-major)"
    },
    {
      "description": "Group all non-major Node dependency updates into one PR",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Node dependencies (non-major)"
    },
    {
      "description": "Group Docker base image updates",
      "matchManagers": ["dockerfile"],
      "groupName": "Docker base images"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Major updates always get their own PR for visibility",
      "matchUpdateTypes": ["major"],
      "groupName": null,
      "addLabels": ["major-update"]
    }
  ]
}